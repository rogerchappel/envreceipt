{
  "name": "envreceipt",
  "version": "0.1.0",
  "description": "Redacted environment receipt and diff CLI.",
  "type": "module",
  "bin": {
    "envreceipt": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/**/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "node scripts/package-smoke.mjs",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke",
    "lint": "npm run check"
  },
  "keywords": [
    "cli",
    "environment",
    "redaction",
    "reproducibility",
    "receipt",
    "diff"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/envreceipt.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/envreceipt/issues"
  },
  "homepage": "https://github.com/rogerchappel/envreceipt#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
